# Sensitive data - never commit
data/
docs/

# Excepcion: web/data/ contiene JSON exportados para GitHub Pages (sin datos sensibles)
!web/data/
!web/data/*.json

# SQL scripts and internal documentation (local only)
sql/
CLAUDE.md
DESIGN_CONTEXT.md

# Scripts de inicio (solo en PC local)
*.vbs
*.bat

# Claude Code local settings (may contain command history with credentials)
.claude/

# Environment variables (DB credentials)
api/.env
api/node_modules/
api/.token-cache.json

# Python
__pycache__/
*.pyc
*.pyo
sql/__pycache__/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Exported CSV data — sensitive
web/data/*.csv

# Logs
*.log
