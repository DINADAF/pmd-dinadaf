# Sensitive data - never commit
data/
docs/*.pdf
docs/*.docx

# Claude Code local settings (may contain command history with credentials)
.claude/

# Environment variables (DB credentials)
api/.env
api/node_modules/

# Python
__pycache__/
*.pyc
*.pyo
sql/__pycache__/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Exported data CSVs (go to SharePoint)
web/data/*.csv
# JSON exports ARE committed so GitHub Pages always shows data
# web/data/*.json

# Logs
*.log
