# Sensitive data - never commit
data/
docs/

# SQL scripts and internal documentation (local only)
sql/
CLAUDE.md
DESIGN_CONTEXT.md

# Scripts de inicio (solo en PC local)
*.vbs
*.bat

# Claude Code local settings (may contain command history with credentials)
.claude/

# Environment variables (DB credentials)
api/.env
api/node_modules/
api/.token-cache.json

# Python
__pycache__/
*.pyc
*.pyo
sql/__pycache__/

# OS
.DS_Store
Thumbs.db
desktop.ini

# Exported data — NEVER commit to public repo (goes to SharePoint only)
# GitHub Pages reads from SharePoint via Microsoft Graph API
web/data/*.csv
web/data/*.json

# Logs
*.log
